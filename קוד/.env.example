# .env.example — קובץ תצורה מרכזי.
# העתק אותו לקובץ בשם .env (באותה תיקייה) ומלא ערכים אמיתיים.
# כל שאר הקבצים מתייחסים לערכים האלה — לא משכפלים אותם.

NODE_ENV=development

# PostgreSQL (מסד הנתונים)
POSTGRES_USER=archive
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=archive
POSTGRES_PORT=5432

# Redis (תורים וזיכרון מטמון)
REDIS_PORT=6379

# Backend (השרת)
BACKEND_PORT=4000

# סוד לחתימת טוקני התחברות (JWT) — החלף למחרוזת אקראית ארוכה
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend (האתר)
FRONTEND_PORT=3000

# Adminer (צפייה במסד הנתונים בדפדפן)
ADMINER_PORT=8080
